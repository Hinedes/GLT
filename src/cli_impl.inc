void print_usage(const char* prog) {
    std::cerr << "Usage: " << prog << "\n"
              << "  --safetensors <path>     Path to model safetensors (or directory with index)\n"
              << "  --domain-data <path>     Tokenized domain data (.bin)\n"
              << "  --ood-data <path> [...]  Tokenized OOD data (.bin), one or more\n"
              << "  --domain-id <int>        Domain ID (0-based)\n"
              << "  --max-domains <int>      Total number of domains\n"
              << "  --steps <int>            Training steps\n"
              << "  --lr <float>             Learning rate\n"
              << "  --lm-loss-scale <float>  CE loss scale for parity diagnostics (default 1.0)\n"
              << "  --lambda-silence <float> Silence loss weight\n"
              << "  --batch-size <int>       Batch size (must be even)\n"
              << "  --max-len <int>          Maximum sequence length (must match bin file)\n"
              << "  --hidden-dim <int>       Model hidden size (default 2048)\n"
              << "  --intermediate-dim <int> Model FFN intermediate dim (default 11008)\n"
              << "  --vocab-size <int>       Vocabulary size (default 128256)\n"
              << "  --num-layers <int>       Number of transformer layers (default 36)\n"
              << "  --num-heads <int>        Number of attention heads (default 16)\n"
              << "  --num-kv-heads <int>     Number of KV heads (default 4)\n"
              << "  --head-dim <int>         Head dimension (default auto: hidden/heads)\n"
              << "  --slice-dim <int>        Graft slice dimension (default 2752)\n"
              << "  --rope-theta <float>     RoPE theta (default 5000000.0)\n"
              << "  --rope-layer-mask <str>  Comma-separated 1/0 per layer, 1=apply RoPE (default: apply all)\n"
              << "  --output <path>          Output path for trained weights\n"
              << "  --checkpoint <path>      Load existing checkpoint (training resume or shadow-eval)\n"
              << "  --session-id <str>       Training session identifier (shared by sibling grafts)\n"
              << "  --seed <int>             Deterministic corpus start seed (default 42)\n"
              << "  --beta1 <float>          Adam beta1 (default 0.9)\n"
              << "  --beta2 <float>          Adam beta2 (default 0.999)\n"
              << "  --adam-eps <float>       Adam epsilon (default 1e-8)\n"
              << "  --weight-decay <float>   Adam weight decay (default 0.01)\n"
              << "  --grad-clip <float>      Global L2 gradient clip norm (default 1.0)\n"
              << "  --warmup-steps <int>     Linear LR warmup steps (default 20)\n"
              << "  --threads <int>          HIP kernel threads per block (default 256)\n"
              << "  --graft-layer-start <int> First layer to graft (default 0)\n"
              << "  --graft-layer-end <int>   Last layer to graft inclusive (default 35)\n"
              << "  --graft-proj-gate <int>   Graft gate projection (0/1, default 0)\n"
              << "  --graft-proj-up <int>     Graft up projection (0/1, default 0)\n"
              << "  --graft-proj-down <int>   Graft down projection (0/1, default 1)\n"
              << "  --allow-expansion-trap    Allow gate+up ablation for explicit ablations\n"
              << "  --eval-only              Run base or explicit-graft eval (no training)\n"
              << "  --shadow-eval            Run shadow-baked eval (startup bake, then native GEMMs)\n"
              << "  --eval-data <path>       Tokenized eval data (.bin) for --eval-only or --shadow-eval\n"
              << "  --graft-gemm-backend <s>  rocblas|hipblaslt-selective (default rocblas)\n"
              << "  --delta-bf16-mirror       Maintain optional bf16 delta mirror (opt-in)\n"
              << "  --use-aten-delta-input-grad Use ATen fallback for delta input-grad GEMMs\n"
              << "  --profile-graft-gemms     Record per-kind graft GEMM counters/timing\n"
              << "  --parity-dump <dir>      Dump one-step forward/backward/optimizer tensors for parity test\n"
              << "  --parity-dump-layer <i>  Layer index to dump in parity mode (default: last)\n"
              << "  --init-deltas <file>     Load initial delta weights from raw float32 file (parity mode)\n"
              << "  --contract-probe         Run a one-hot synthetic down-contract probe during parity dump\n"
              << "  --verbose                Enable diagnostic debug prints\n";
}
